# Database
# macOS Homebrew: postgresql://YOUR_USERNAME@localhost:5432/shiftsync_app
# Docker: postgresql://postgres:postgres@localhost:5432/shiftsync_app
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shiftsync_app?schema=public"

# Server
PORT=3001
NODE_ENV=development

# Auth (development)
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"

# CORS
FRONTEND_URL="http://localhost:5173"

# AI (mock | llama when integrated)
AI_PROVIDER="mock"
