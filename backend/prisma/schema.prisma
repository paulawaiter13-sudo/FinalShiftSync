generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OPERATOR
  SHIFT_MANAGER
  ADMIN
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

enum ShiftStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum IncidentCategory {
  INFRASTRUCTURE
  APPLICATION
  SECURITY
  NETWORK
  DATABASE
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum IncidentSource {
  MANUAL
  MONITORING
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  NEW
  ACKNOWLEDGED
  CONVERTED_TO_INCIDENT
  DISMISSED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum AnnouncementPriority {
  NORMAL
  IMPORTANT
  URGENT
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(OPERATOR)
  createdAt    DateTime @default(now())

  shifts              Shift[]
  assignedIncidents   Incident[]      @relation("AssignedIncidents")
  assignedTasks       Task[]          @relation("AssignedTasks")
  announcements       Announcement[]
  incidentNotes       IncidentNote[]
}

model Shift {
  id            String      @id @default(cuid())
  shiftType     ShiftType
  startTime     DateTime
  endTime       DateTime
  responsibleId String
  status        ShiftStatus @default(PLANNED)
  handoverNotes String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  responsible User          @relation(fields: [responsibleId], references: [id])
  incidents   Incident[]
  tasks       Task[]
  summaries   ShiftSummary[]
  alerts      Alert[]
}

model Incident {
  id             String           @id @default(cuid())
  title          String
  description    String
  category       IncidentCategory
  severity       IncidentSeverity
  status         IncidentStatus   @default(OPEN)
  relatedService String?
  assignedUserId String?
  shiftId        String?
  source         IncidentSource   @default(MANUAL)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  resolvedAt     DateTime?

  assignedUser User?          @relation("AssignedIncidents", fields: [assignedUserId], references: [id])
  shift        Shift?         @relation(fields: [shiftId], references: [id])
  alert        Alert?
  notes        IncidentNote[]
}

model IncidentNote {
  id         String   @id @default(cuid())
  incidentId String
  authorId   String
  content    String
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])
}

model Alert {
  id           String        @id @default(cuid())
  title        String
  description  String
  service      String
  severity     AlertSeverity
  status       AlertStatus   @default(NEW)
  sourceSystem String
  shiftId      String?
  incidentId   String?       @unique
  createdAt    DateTime      @default(now())

  shift    Shift?    @relation(fields: [shiftId], references: [id])
  incident Incident? @relation(fields: [incidentId], references: [id])
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(OPEN)
  priority       TaskPriority @default(MEDIUM)
  assignedUserId String?
  shiftId        String?
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assignedUser User?  @relation("AssignedTasks", fields: [assignedUserId], references: [id])
  shift        Shift? @relation(fields: [shiftId], references: [id])
}

model ShiftSummary {
  id            String   @id @default(cuid())
  shiftId       String
  generatedText String   @db.Text
  generatedAt   DateTime @default(now())
  generatedByAI Boolean  @default(true)

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String               @id @default(cuid())
  title     String
  content   String               @db.Text
  priority  AnnouncementPriority @default(NORMAL)
  createdBy String
  createdAt DateTime             @default(now())
  expiresAt DateTime?

  creator User @relation(fields: [createdBy], references: [id])
}
